@model IEnumerable<ApexUSCommerce.Models.Product>
@{
    ViewData["Title"] = "Premium USA Goods Catalog";
    var categories = ViewData["CategoriesList"] as IEnumerable<ApexUSCommerce.Models.Category> ?? new List<ApexUSCommerce.Models.Category>();
}

<div class="row mb-5 align-items-center">
    <div class="col-md-8">
        <h1 class="font-weight-black tracking-tight text-slate-900 display-5">Premium US Catalog</h1>
        <p class="text-muted leading-relaxed">Discover reliable tech accessories, durable outdoor hiking collections, seasoned iron skills, and timeless plaid clothing. Shipped across the USA.</p>
    </div>
    <div class="col-md-4 text-md-end">
        <span class="badge bg-indigo-subtle border border-indigo-primary text-indigo-emphasis px-3 py-2 text-xs font-mono">⚡ FLAT-RATE USA FAST SHIPPING</span>
    </div>
</div>

<div class="row g-4">
    <!-- Left Navigation filter column -->
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm p-4 rounded-3 bg-white mb-4">
            <h5 class="font-bold border-bottom pb-2 mb-3 text-uppercase font-mono text-xs text-muted">Category Department</h5>
            <div class="list-group list-group-flush">
                <a href="@Url.Action("Index", "Home", new { search = ViewData["SearchQuery"] })" 
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 py-2 @(ViewData["CategorySlug"] == null ? "fw-bold text-primary" : "text-muted")">
                    <span><i class="bi bi-grid-fill me-2 small"></i> All Goods</span>
                </a>
                @foreach (var cat in categories)
                {
                    <a href="@Url.Action("Index", "Home", new { category = cat.Slug, search = ViewData["SearchQuery"] })" 
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 py-2 @(ViewData["CategorySlug"]?.ToString() == cat.Slug ? "fw-bold text-primary" : "text-muted")">
                        <span><i class="bi bi-tag-fill me-2 small"></i> @cat.Name</span>
                    </a>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
            <h5 class="font-bold border-bottom pb-2 mb-3 text-uppercase font-mono text-xs text-muted">Arrange Sorting</h5>
            <div class="list-group list-group-flush font-mono text-xs">
                <a href="@Url.Action("Index", "Home", new { category = ViewData["CategorySlug"], search = ViewData["SearchQuery"], sort = "newest" })" 
                   class="list-group-item list-group-item-action border-0 px-0 py-2 @(ViewData["CurrentSort"]?.ToString() == "newest" || ViewData["CurrentSort"] == null ? "fw-bold text-primary" : "text-muted")">
                    Newest Stock
                </a>
                <a href="@Url.Action("Index", "Home", new { category = ViewData["CategorySlug"], search = ViewData["SearchQuery"], sort = "price_asc" })" 
                   class="list-group-item list-group-item-action border-0 px-0 py-2 @(ViewData["CurrentSort"]?.ToString() == "price_asc" ? "fw-bold text-primary" : "text-muted")">
                    Price: Low to High
                </a>
                <a href="@Url.Action("Index", "Home", new { category = ViewData["CategorySlug"], search = ViewData["SearchQuery"], sort = "price_desc" })" 
                   class="list-group-item list-group-item-action border-0 px-0 py-2 @(ViewData["CurrentSort"]?.ToString() == "price_desc" ? "fw-bold text-primary" : "text-muted")">
                    Price: High to Low
                </a>
            </div>
        </div>
    </div>

    <!-- Products grid listings -->
    <div class="col-lg-9">
        @if (!Model.Any())
        {
            <div class="text-center bg-white shadow-sm border rounded-4 p-5">
                <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
                <h4 class="fw-bold">No premium stock matches selection</h4>
                <p class="text-muted text-sm mb-4">Try checking spelling parameters or removing department filters.</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4 py-2 text-xs font-bold shadow-sm rounded-3">Reset Catalog Filters</a>
            </div>
        }
        else
        {
            <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 product-card bg-white border-0 shadow-sm flex flex-column">
                            <div class="position-relative aspect-ratio-box overflow-hidden bg-light" style="padding-top: 75%;">
                                @if (item.ProductImages.Any())
                                {
                                    <img src="@item.ProductImages.First().ImageUrl" alt="@item.Name" class="w-100 h-100 object-fit-cover position-absolute top-0 start-0" />
                                }
                                else
                                {
                                    <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=600&q=80" alt="@item.Name" class="w-100 h-100 object-fit-cover position-absolute top-0 start-0" />
                                }
                                <div class="position-absolute top-0 start-0 m-3 badge bg-slate-900 border font-mono tracking-tight text-white py-1.5 px-2.5">
                                    @item.SKU
                                </div>
                                @if (item.Stock <= 5 && item.Stock > 0)
                                {
                                    <div class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark font-mono font-bold">
                                        LOW STOCK
                                    </div>
                                }
                            </div>

                            <div class="card-body p-4 d-flex flex-column justify-content-between h-[200px]">
                                <div>
                                    <span class="text-xs text-uppercase font-bold tracking-widest text-primary font-mono block">@item.Category?.Name</span>
                                    <h5 class="fw-bold text-slate-900 text-truncate mt-1">@item.Name</h5>
                                    <p class="card-text text-muted small text-truncate-2 leading-relaxed">@item.Description</p>
                                </div>

                                <div class="d-flex align-items-center justify-content-between border-top pt-3 mt-4">
                                    <div>
                                        <span class="text-xs text-muted block">USD Price</span>
                                        <span class="fw-black text-slate-900 fs-5 font-bold">$@item.Price.ToString("F2")</span>
                                    </div>

                                    <div class="btn-group">
                                        <a href="@Url.Action("Details", "Home", new { id = item.Id })" class="btn btn-outline-dark btn-sm rounded-start-3 px-3">
                                            Info
                                        </a>
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <button type="submit" class="btn btn-primary btn-sm rounded-end-3 px-3 shadow-md shadow-primary-subtle">
                                                <i class="bi bi-cart-plus"></i> Add
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
