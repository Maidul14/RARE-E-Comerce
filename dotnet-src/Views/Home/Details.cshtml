@model ApexUSCommerce.Models.Product
@{
    ViewData["Title"] = Model.Name + " - Product Details";
    var recommendations = ViewData["Recommendations"] as IEnumerable<ApexUSCommerce.Models.Product> ?? new List<ApexUSCommerce.Models.Product>();
}

<div class="mb-4">
    <a href="@Url.Action("Index", "Home")" class="btn btn-light btn-sm border px-3 py-2 rounded-3 text-muted"><i class="bi bi-arrow-left"></i> Return to Shop</a>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white p-4 p-md-5 mb-5">
    <div class="row g-5">
        <div class="col-md-6">
            <div class="aspect-ratio-box rounded-3 overflow-hidden bg-light border" style="padding-top: 75%; position: relative;">
                @if (Model.ProductImages.Any())
                {
                    <img src="@Model.ProductImages.First().ImageUrl" alt="@Model.Name" class="w-100 h-100 object-fit-cover position-absolute top-0 start-0" />
                }
                else
                {
                    <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=600&q=80" alt="@Model.Name" class="w-100 h-100 object-fit-cover position-absolute top-0 start-0" />
                }
            </div>

            <!-- Carousel grid under big image -->
            @if (Model.ProductImages.Count > 1)
            {
                <div class="d-flex align-items-center gap-3 mt-3 overflow-x-auto py-1">
                    @foreach (var img in Model.ProductImages)
                    {
                        <div class="rounded-3 border overflow-hidden bg-light" style="width: 80px; height: 60px;">
                            <img src="@img.ImageUrl" alt="" class="w-100 h-100 object-fit-cover" />
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-between">
            <div>
                <span class="badge bg-primary-subtle border border-primary text-primary px-3 py-1.5 rounded-pill text-xs font-mono uppercase">@Model.Category?.Name</span>
                <h2 class="fw-black text-slate-900 tracking-tight mt-3 mb-4 display-6">@Model.Name</h2>

                <div class="row g-4 mb-4 border-top border-bottom py-3 text-xs uppercase font-mono tracking-wider">
                    <div class="col-6">
                        <span class="text-muted block">Stock Integrity</span>
                        @if (Model.Stock > 0)
                        {
                            <span class="fw-bold text-success"><i class="bi bi-check-circle-fill"></i> In Stock (@Model.Stock)</span>
                        }
                        else
                        {
                            <span class="fw-bold text-danger"><i class="bi bi-x-circle-fill"></i> Out of Stock</span>
                        }
                    </div>
                    <div class="col-6">
                        <span class="text-muted block">Registered SKU</span>
                        <span class="fw-bold text-dark">@Model.SKU</span>
                    </div>
                </div>

                <div class="fs-3 fw-black text-slate-900 mb-4 font-sans font-bold">$@Model.Price.ToString("F2") <span class="fs-6 text-muted font-normal font-sans">USD</span></div>

                <div class="mb-4">
                    <h6 class="text-muted text-uppercase text-xs font-bold font-mono tracking-wider mb-2">Item Specifications</h6>
                    <p class="text-muted leading-relaxed small">@Model.Description</p>
                </div>
            </div>

            <div class="border-top pt-4 mt-4">
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="row g-3">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="col-auto">
                        <label class="visually-hidden">Quantity</label>
                        <select name="quantity" class="form-select px-3 rounded-3" style="width: 90px;">
                            @for (int i = 1; i <= Math.Min(10, Model.Stock); i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                    <div class="col">
                        <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-3 fw-bold shadow-md shadow-primary-subtle" @(Model.Stock == 0 ? "disabled" : "")>
                            <i class="bi bi-cart-plus me-1"></i> Add to Checkout Cart
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
